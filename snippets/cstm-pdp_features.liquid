{% style %}

.pdp_custom-feature-list-item__image {
    max-width: 18px;
    width: 100%;
    height: auto;
    min-width: 18px;
}

.pdp_custom-feature-list-item__image img{
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

ul.pdp_custom-feature-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin: 0;
    gap: 24px;
}

li.pdp_custom-feature-list-item {
    list-style-type: none;
    display: flex;
    align-items: center;
    gap: 6px;
    max-width: fit-content;
    width: 100%;
}

span.pdp_custom-feature-list-item__text {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 14px;
    line-height: 22.8px;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    color: #000;
    min-width: fit-content;
}

@media screen and (max-width: 767px) {
    ul.pdp_custom-feature-list {
        gap: 8px;
    }

    
}

{% endstyle %}

<ul class="pdp_custom-feature-list">

  {% for i in (1..3) %}
    {% assign text_key = 'list_item_' | append: i %}
    {% assign icon_key = 'list_icon_' | append: i %}

    {% assign item_text = block.settings[text_key] %}
    {% assign item_icon = block.settings[icon_key] %}

    {% if item_text != blank %}
      <li class="pdp_custom-feature-list-item">
        
        {% if item_icon != blank %}
          <div class="pdp_custom-feature-list-item__image">
            {{ item_icon | image_url: width: 1600 | image_tag:
              widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
              alt: item_text,
              loading: "lazy"
            }}
          </div>
        {% endif %}

        <span class="pdp_custom-feature-list-item__text">
          {{ item_text }}
        </span>

      </li>
    {% endif %}
  {% endfor %}

</ul>
