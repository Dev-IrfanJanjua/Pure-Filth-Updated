<ul class="pdp-icon-list">
  {% for i in (1..6) %}
    {% assign icon_id = 'icon_' | append: i %}
    {% assign alt_text = 'icon ' | append: i %}

    {% if block.settings[icon_id] %}
        <li class="pdp-icon-list-item">
            {{
            block.settings[icon_id]
            | image_url: width: 1600
            | image_tag:
                widths: '50,100,150,200,250,300,400,500,600,1440',
                alt: 'alt_text',
                loading: 'lazy'
            }}
        </li>     
    {% endif %}
  {% endfor %}
</ul>


{% style %}

.pdp-icon-list {
  display: flex;
  list-style-type: none;
  padding: 0;
  margin: 0;
  gap: 12px;
    align-items: center;
    justify-content: center;
    margin-top: 32px;
}

.pdp-icon-list-item {
    width: 100%;
    height: auto;
    flex-shrink: 0;
    max-width: calc(16.66% - 10px);
}

.pdp-icon-list-item img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

@media screen and (max-width: 768px){

.pdp-icon-list {
    gap: 19px;
    margin-top: 24px;
    flex-wrap: wrap;
    padding: 40px 0;
}

.pdp-icon-list-item {
    max-width: calc(33.3% - 13px);
    width: 100%;
    height: 80px;
    flex-shrink: 0;
}

}

{% endstyle %}