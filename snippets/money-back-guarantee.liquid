<div class="pdp-moneyback">
  <p class="pdp-moneyback-text">{{ block.settings.money_text }}</p>
</div>

{% style %}
  
.pdp-moneyback {
    padding: 5px;
    background: {{ block.settings.bg_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    margin-top: 16px;
}

.pdp-moneyback-text {
    font-family: GT Cinetype;
    font-weight: 700;
    font-size: 14px;
    line-height: 22.8px;
    letter-spacing: 0;
    text-align: center;
    vertical-align: middle;
    text-transform: capitalize;
    margin: 0;
    color: {{ block.settings.text_color }};
}

{% endstyle %}
