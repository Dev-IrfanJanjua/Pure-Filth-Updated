  function updatePriceDisplay(input) {
  const label = document.querySelector(`label[for="${input.id}"]`);
  if (!label) return;

  const price = label.getAttribute('data-price');
  const discPrice = label.getAttribute('data-disc_price');
  const compPrice = label.getAttribute('data-comp_price');
  const servingPrice = label.getAttribute('data-serving');

  const priceEls = document.querySelectorAll('.pdp_price');
  const comparePriceEls = document.querySelectorAll('.pdp_compare_price');
  const compPriceEls = document.querySelectorAll('.pdp_compare_price_compare');
  const servingEls = document.querySelectorAll('.pdp_purchase-option_selling-prices_serving');

  priceEls.forEach(el => {
    el.textContent = price || '';
  });

  comparePriceEls.forEach(el => {
    el.textContent = discPrice || '';
  });

  compPriceEls.forEach(el => {
    el.textContent = compPrice || '';
  });

  servingEls.forEach(el => {
    el.textContent = servingPrice || '';
  });

}

  // Handle swatch change
  document.addEventListener('change', function (e) {
    if (e.target.matches('input[data-color]')) {
      updatePriceDisplay(e.target);
    }
  });

  // On page load
  document.addEventListener('DOMContentLoaded', function () {
    const swatches = document.querySelectorAll('input[data-color]');
    let checked = document.querySelector('input[data-color]:checked');

    // If none are checked, default to first swatch
    if (!checked && swatches.length) {
      checked = swatches[0];
      checked.checked = true;
    }

    if (checked) updatePriceDisplay(checked);
  });
</script>