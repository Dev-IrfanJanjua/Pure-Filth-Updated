<script>
document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll(".pdp_tabs").forEach((tabsWrapper) => {

    const buttons = tabsWrapper.querySelectorAll(".pdp_tabs__btn");
    const panes = tabsWrapper.querySelectorAll(".pdp_tabs__pane");

    // Tab click (desktop)
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tab = btn.getAttribute("data-tab");

        buttons.forEach(b => b.classList.remove("active"));
        panes.forEach(p => p.classList.remove("active"));

        btn.classList.add("active");
        tabsWrapper.querySelector(`[data-content="${tab}"]`).classList.add("active");
      });
    });

    // Accordion click (mobile)
    const headers = tabsWrapper.querySelectorAll(".pdp_tabs__pane-header");
    headers.forEach((header) => {
      header.addEventListener("click", () => {
        const pane = header.parentElement;
        const content = pane.querySelector(".pdp_tabs__pane-content");

        if (pane.classList.contains("active")) {
          // Close accordion
          content.style.maxHeight = '0px';
          pane.classList.remove("active");
        } else {
          // Close other panes (if only one open at a time)
          panes.forEach(p => {
            p.classList.remove("active");
            p.querySelector(".pdp_tabs__pane-content").style.maxHeight = '0px';
          });

          // Open clicked pane
          pane.classList.add("active");
          content.style.maxHeight = content.scrollHeight + 'px';
        }
      });
    });

    // Set initial max-height for any active panes (on page load)
    panes.forEach(p => {
      const content = p.querySelector(".pdp_tabs__pane-content");
      if (p.classList.contains("active")) {
        content.style.maxHeight = content.scrollHeight + 'px';
      }
    });

  });
});
</script>