{% style %}

.pdp_tabs__nav {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}

.pdp_tabs__btn {
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
    font-family: GT Cinetype;
    font-weight: 700;
    font-size: 20px;
    line-height: 23px;
    letter-spacing: 0px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color: #000;
    transition: all 0.3s ease;
}

.pdp_tabs__btn.active::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -1px;
  width: 100%;
  height: 2px;
  background: {{ block.settings.border_clr }} ; /* green underline */
}

.pdp_tabs__pane {
    display: none;
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0;
    color: #000;
    transition: all 0.3s ease;
}

.pdp_tabs__pane-content {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0.3px;
    color: #000;
}

.pdp_tabs__pane.active {
  display: block;
}

.pdp_tabs {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-top: 2px solid #00000033;
    padding-top: 32px;
}

.pdp_tabs__pane-header{
    display: none;
}

/* Accordion for mobile */
@media (max-width: 768px) {
  .pdp_tabs__nav {
    display: none; /* hide tabs navigation on mobile */
  }

  .pdp_tabs__pane {
    display: block;
    border-bottom: 1px dashed #767676;
  }

  .pdp_tabs{
    margin-top: 24px;
    padding: 0;
  }

  .pdp_tabs__pane-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    padding: 20px 0;
  }

  .pdp_tabs__pane-content {
    max-height: 0;
    overflow: hidden;
    padding-bottom: 0;
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0;
    transition: all 0.3s ease;
  }

  .pdp_tabs__pane.active .pdp_tabs__pane-content {
    max-height: 500px;
  }

  span.pdp_tabs__pane-header_text {
    font-family: GT Cinetype;
    font-weight: 700;
    font-size: 16px;
    line-height: 22px;
    letter-spacing: 0;
    text-transform: uppercase;
    color: #000;
}

.pdp_tabs__pane.active {
  padding-bottom: 20px;
}

span.pdp_tabs__pane-header_icon_minus {
    display: none;
}

.pdp_tabs__pane.active span.pdp_tabs__pane-header_icon_minus {
    display: block;
}

.pdp_tabs__pane.active  span.pdp_tabs__pane-header_icon_plus {
    display: none;
}

}


{% endstyle %}

