  } */
{% endstyle %}

<section class="comparison-section section-{{ section.id }}">
    {% if section.settings.image_bg_mob != blank %}
        <div class="comparison_section-img">
            {% if section.settings.image_bg_mob != blank %}
                {{ section.settings.image_bg | image_url: width: 1600 | image_tag:
                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                    alt: "image",
                    loading: "eager",
                    class: 'comparison_section-img-desk'
                }}
            {% endif %}
            {% if section.settings.image_bg_mob != blank %}
                {{ section.settings.image_bg_mob | image_url: width: 1600 | image_tag:
                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                    alt: "image",
                    loading: "eager",
                    class: 'comparison_section-img-mob',
                    style: 'display: none;'
                }}
            {% endif %}
        </div>
    {% endif %}
  <div class="page-width">
    <div class="comparison-head">
      {% if section.settings.title != blank %}
        <h2 class="comparison-title">
          {{ section.settings.title }}
        </h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="comparison-subtitle">
          {{ section.settings.subtitle }}
        </p>
      {% endif %}
    </div>

    <div class="comparison_table-wrapper">
      <table class="comparison_table">
        <thead>
          <tr>
            <th class="col-feature">
              {{ section.settings.col_1 }}
            </th>

            <th class="col-brand highlight comparison-logo">
              {% if section.settings.brand_logo != blank %}
                {{ section.settings.brand_logo | image_url: width: 200 | image_tag }}
              {% else %}
                {{ section.settings.col_2 }}
              {% endif %}
            </th>

            <th class="col-typical">
              {{ section.settings.col_3 }}
            </th>

            <th class="col-why">
              {{ section.settings.col_4 }}
            </th>
          </tr>
        </thead>

        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <td class="col-feature">
                {{ block.settings.feature }}
              </td>

              <td class="col-brand highlight">
                <span class="comparison-cell_inner-text">
                  {{ block.settings.brand }}
                </span>
              </td>

              <td class="col-typical">
                <span class="comparison-cell_inner-text">
                  {{ block.settings.typical }}
                </span>
              </td>

              <td class="col-why">
                {{ block.settings.why }}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison (Scrollable)",
  "settings": [

    {
      "type": "image_picker",
      "id": "image_bg",
      "label": "Section Background Image Desktop"
    },
    {
      "type": "image_picker",
      "id": "image_bg_mob",
      "label": "Section Background Image Mobile"
    },

    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },

    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },

    {
      "type": "text",
      "id": "col_1",
      "label": "Column 1 Heading",
      "default": "Features"
    },

    {
      "type": "text",
      "id": "col_2",
      "label": "Column 2 Heading",
      "default": "Your Brand"
    },

    {
      "type": "text",
      "id": "col_3",
      "label": "Column 3 Heading",
      "default": "Typical Brands"
    },

    {
      "type": "text",
      "id": "col_4",
      "label": "Column 4 Heading",
      "default": "Why This Matters"
    },

    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Brand Logo (optional)"
    },

    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "highlight_bg",
      "label": "Highlight Column Background",
      "default": "#f0f0f0"
    },

    {
      "type": "color_background",
      "id": "table_head_bg",
      "label": "Table Header Background",
      "default": "#f5f5f5"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "label": "Padding Top Desktop"
    },

    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 80,
      "label": "Padding Bottom Desktop"
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40,
      "label": "Padding Top Mobile"
    },

    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40,
      "label": "Padding Bottom Mobile"
    }
  ],

  "blocks": [
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature"
        },

        {
          "type": "textarea",
          "id": "brand",
          "label": "Your Brand"
        },

        {
          "type": "textarea",
          "id": "typical",
          "label": "Typical Brands"
        },

        {
          "type": "textarea",
          "id": "why",
          "label": "Why This Matters"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Comparison Table (Scrollable)",
      "category": "Custom",
      "blocks": [{ "type": "row" }, { "type": "row" }, { "type": "row" }, { "type": "row" }]
    }
  ]
}
{% endschema %}
