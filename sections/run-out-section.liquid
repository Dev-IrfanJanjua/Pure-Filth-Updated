{% style %}

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.section-{{ section.id }} .page-width{
    padding: 0 74px;
}

.section-{{ section.id }} .run-out-wrapper{
  background: {{ section.settings.wrapper_bg }};
    padding-left: 60px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-radius: 24px;
    overflow: hidden;
}

.section-{{ section.id }} .run-out-content{
    max-width: calc(100% - (43% - 10px));
    width: 100%;
}

.section-{{ section.id }} .run-out-image{
    max-width: 43%;
    width: 100%;
    height:auto;
}

.section-{{ section.id }} .run-out-image img{
  width:100%;
  height:100%;
  object-fit: cover;
  display:block;
}

.section-{{ section.id }} .run-out-head{
  margin-bottom: 40px;
}

.section-{{ section.id }} .run-out-title{
    margin: 0 0 16px;
    font-family: PP Formula;
    font-weight: 700;
    font-size: 62px;
    line-height: 100%;
    letter-spacing: 1px;
    vertical-align: middle;
    text-transform: uppercase;
    color: #000;
}

p.run-out-subtitle {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 0px;
    vertical-align: middle;
    margin: 0;
    color: #000;
}

.section-{{ section.id }} .run-out-blocks{
    list-style: none;
    padding: 0;
    display: flex;
    gap: 20px;
    margin: 0;
    flex-wrap: wrap;
}

.section-{{ section.id }} .run-out-block{
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: calc(50% - 10px);
    width: 100%;
}

.run-out-block-icon {
    max-width: 56px;
    width: 100%;
    height: 56px;
}

.section-{{ section.id }} .run-out-block-icon img{
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.run-out-block-text {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 16px;
    line-height: 22.4px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
    margin: 0;
}

.run-out-block-text p{
    margin: 0;
}

.section-{{ section.id }} .run-out-button{
  display:inline-flex;
  align-items:center;
  gap:10px;
  text-decoration:none;
  background: {{ section.settings.button_bg }};
  padding:10px 16px;
  border-radius:75px;
  transition:all .3s ease;
  margin-top: 40px;
}

span.run-out-btn-text {
    color: #fff;
    font-family: GT Cinetype;
    font-weight: 700;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0px;
    text-transform: uppercase;
}

.section-{{ section.id }} .run-out-button:hover {
  transform:translateY(-2px);
}

.section-{{ section.id }} .run-out-button:hover .run-out-btn-icon{
  transform:translateX(4px);
}

.section-{{ section.id }} .run-out-btn-icon{
  background: {{ section.settings.button_icon_bg }};
  display:flex;
  align-items:center;
  justify-content:center;
  padding:10px 12px;
  border-radius:60px;
  transition:all .3s ease;
}

.section-{{ section.id }} .run-out-btn-icon img{
  width: 26px;
  height: 16px;
}

/* Mobile */

@media(max-width:768px){

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_mobile }}px;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
}

.section-{{ section.id }} .page-width{
    padding: 0 16px;
}

.section-{{ section.id }} .run-out-wrapper{
      flex-direction: column;
    padding: 40px 8px 0;
}

.section-{{ section.id }} .run-out-content {
    max-width: 100%;
    text-align: center;
}

.section-{{ section.id }} .run-out-head {
    margin-bottom: 24px;
}

.section-{{ section.id }} .run-out-title {
    font-size: 40px;
    line-height: 44px;
}

p.run-out-subtitle {
    font-size: 14px;
    line-height: 22px;
}

.section-{{ section.id }} .run-out-blocks {
    list-style: none;
    padding: 0;
    display: flex;
    gap: 24px;
    margin: 0;
    flex-wrap: wrap;
}

.section-{{ section.id }} .run-out-block {
    flex-direction: column;
    max-width: calc(50% - 12px);
}

.run-out-block-text {
    font-size: 14px;
    line-height: 22px;
}

.run-out-block-icon {
    max-width: 40px;
    width: 100%;
    height: 40px;
}

.section-{{ section.id }} .run-out-image {
    max-width: 100%;
    width: 100%;
    height: auto;
}

.section-{{ section.id }} .run-out-image .run-out-image_desk{
    display: none !important;
}

.section-{{ section.id }} .run-out-image .run-out-image_mob{
    display: block !important;
}

}

{% endstyle %}


<section class="run-out-section section-{{ section.id }}">
    <div class="page-width">
        <div class="run-out-wrapper">

            <div class="run-out-content">

                <div class="run-out-head">

                    {% if section.settings.title != blank %}
                    <h2 class="run-out-title">
                        {{ section.settings.title }}
                    </h2>
                    {% endif %}

                    {% if section.settings.subtitle != blank %}
                    <p class="run-out-subtitle">
                        {{ section.settings.subtitle }}
                    </p>
                    {% endif %}

                </div>


                {% if section.blocks.size > 0 %}
                <ul class="run-out-blocks">

                    {% for block in section.blocks %}
                    <li class="run-out-block" {{ block.shopify_attributes }}>

                        {% if block.settings.icon != blank %}
                        <div class="run-out-block-icon">
                            {{ block.settings.icon | image_url: width:100 | image_tag }}
                        </div>
                        {% endif %}

                        {% if block.settings.text != blank %}
                        <span class="run-out-block-text">
                            {{ block.settings.text }}
                        </span>
                        {% endif %}

                    </li>
                    {% endfor %}

                </ul>
                {% endif %}


                {% if section.settings.button_text != blank %}
                <a href="{{ section.settings.button_link }}" class="run-out-button">

                    <span class="run-out-btn-text">
                        {{ section.settings.button_text }}
                    </span>

                    {% if section.settings.button_icon != blank %}
                    <div class="run-out-btn-icon">
                        {{ section.settings.button_icon | image_url: width:100 | image_tag }}
                    </div>
                    {% endif %}

                </a>
                {% endif %}

            </div>


            {% if section.settings.image != blank or section.settings.image_mob != blank %}
            <div class="run-out-image">
                {% if section.settings.image != blank %}
                    {{ section.settings.image | image_url: width:1600 | image_tag: class: 'run-out-image_desk' }}
                {% endif %}
                {% if section.settings.image_mob != blank %}
                    {{ section.settings.image_mob | image_url: width:1600 | image_tag: class: 'run-out-image_mob', style : 'display: none;' }}
                {% endif %}
            </div>
            {% endif %}

        </div>
    </div>
</section>


{% schema %}
{
  "name": "Run Out Section",
  "settings": [

    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },

    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },

    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Image Desktop"
    },
    {
      "type": "image_picker",
      "id": "image_mob",
      "label": "Right Image Mobile"
    },

    {
      "type": "color",
      "id": "wrapper_bg",
      "label": "Wrapper Background Color",
      "default": "#f5f5f5"
    },

    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "button_icon_bg",
      "label": "Button Icon Background",
      "default": "#ffffff"
    },

    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Top Desktop",
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Bottom Desktop",
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Top Mobile",
      "default": 40
    },

    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Bottom Mobile",
      "default": 40
    }

  ],

  "blocks":[
    {
      "type":"feature",
      "name":"Run Out Block",
      "settings":[

        {
          "type":"image_picker",
          "id":"icon",
          "label":"Block Icon"
        },

        {
          "type":"richtext",
          "id":"text",
          "label":"Block Text"
        }

      ]
    }
  ],

  "presets":[
    {
      "name":"Run Out Section",
      "category": "Custom",
      "blocks":[
        {"type":"feature"},
        {"type":"feature"},
        {"type":"feature"}
      ]
    }
  ]
}
{% endschema %}
