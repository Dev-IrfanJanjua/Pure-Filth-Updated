{% style %}

.section-{{ section.id }}{
  position: relative;
  background: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
}

.section-{{ section.id }}:after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.3);
  pointer-events: none;
}

.hero-abs-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.section-{{ section.id }} .hero-abs-image{
  width: 100%;
  height: 100%;
  max-width: 100%;
}

.section-{{ section.id }} .her-abs-image img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.section-{{ section.id }} .bg_content-wrapper{
    position: absolute;
    top: 80px;
    left: 50%;
    transform: translatex(-50%);
    max-width: 842px;
    text-align: center;
    z-index: 2;
}

.section-{{ section.id }} .mobile-banner{
  display:none;
}

.section-{{ section.id }} .bg_content_button{
    display:inline-flex;
    align-items:center;
    gap: 10px;
    background: {{ section.settings.button_bg }};
    text-decoration:none;
    transition: all .35s ease;
    padding: 10px 16px;
    margin-top: 42px;
    border-radius: 75px;
}

span.her-banner_button-text {
    font-family: GT Cinetype;
    font-weight: 700;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0px;
    text-transform: uppercase;
    color: #000000;
}

.section-{{ section.id }} .bg_content_button-icon{
  background: {{ section.settings.button_icon_bg }};
  display:flex;
  align-items:center;
  justify-content:center;
  transition: all .35s ease;
  max-width: 50px;
    height: auto;
    padding: 10px 12px;
    border-radius: 70px;
}

.bg_content_button-icon img {
    width: 100%;
    height: 16px;
    display: block;
}

.section-{{ section.id }} .bg_content_button:hover{
  transform: translateY(-2px);
}

.section-{{ section.id }} .bg_content_button:hover .bg_content_button-icon{
  transform: translateX(4px);
}

h2.bg_content_title {
    font-family: PP Formula;
    font-weight: 700;
    font-size: clamp(40px, 5vw, 60px);
    line-height: clamp(44px, 5.28vw, 66px);
    letter-spacing: 1px;
    vertical-align: middle;
    text-transform: uppercase;
    color: #fff;
    margin: 0 auto;
}

.bg_content_desc {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 0px;
    vertical-align: middle;
    text-transform: capitalize;
    color: #fff;
    margin-top: 6px;
    max-width: 472px;
    margin-inline: auto;
}

.bg_content_desc ul {
    padding: 0;
    margin: 12px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.bg_content_desc ul li {
    display: flex;
    align-items: center;
    gap: 15px;
}

.bg_content_desc ul li:before {
    content: "";
    width: 24px;
    height: 24px;
    background-image: url({{ section.settings.list_icon | image_url }});
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
}

ul.bg_content-blocks {
    padding: 0;
    margin: 37px 0 0;
    list-style-type: none;
    display: flex;
    align-items: center;
    gap: 28px;
    justify-content: center;
}

.bs_content-block-icon {
    width: 98px;
    height: auto;
    flex-shrink: 0;
}

.bs_content-block-icon img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
}

li.bs_content-block {
    display: flex;
}

@media(max-width:768px){

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_mobile }}px;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
}

.section-{{ section.id }} .desktop-banner{
  display:none;
}

.section-{{ section.id }} .mobile-banner{
  display:block;
}

.section-{{ section.id }} .bg_content-wrapper {
    position: absolute;
    top: 32px;
    left: 16px;
    transform: unset;
    right: 16px;
}

.bg_content_desc {
    font-size: 16px;
    margin-top: 6px;
    line-height: 22px;
}

.bg_content_desc ul {
    margin: 8px 0 0;
    gap: 8px;
}

.bg_content_desc ul li {
    gap: 8px;
}

.bg_content_desc ul li:before {
    width: 16px;
    height: 16px;
}

.section-{{ section.id }} .bg_content_button {
    margin-top: 80px;
}

.section-{{ section.id }} .bg_content_button-icon {
    padding: 8px 9px;
    border-radius: 56px;
}

h2.bg_content_title{
  max-width: 306px;
}

ul.bg_content-blocks {
    flex-wrap: wrap;
    margin: 19px 0 0;
    gap: 20px;
}

}

{% endstyle %}



<section class="bg_content-section section-{{ section.id }} fade-in-section">

    <div class="hero-abs-image">
        {% if section.settings.main_img != blank %}
                {{ section.settings.main_img | image_url: width: 1600 | image_tag:
                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,1440',
                    alt: "image",
                    loading: "eager",
                    class: 'desktop-banner'
                }}
        {% endif %}
        {% if section.settings.mobile_img != blank %}
                {{ section.settings.mobile_img | image_url: width: 1600 | image_tag:
                    widths: '50, 100, 150, 200, 250, 300, 400, 500,600,900',
                    alt: "image",
                    loading: "eager",
                    class: 'mobile-banner'
                }}
        {% endif %}
    </div>

    <div class="page-width">
        <div class="bg_content-wrapper">

            {% if section.settings.title != blank %}
                <h2 class="bg_content_title fade-in-left">{{ section.settings.title | remove: '<p>' | remove: '</p>' }}</h2>
            {% endif %}

            {% if section.settings.description != blank %}
                <div class="bg_content_desc fade-in-left">{{ section.settings.description | remove: '<p>' | remove: '</p>' }}</div>
            {% endif %}

            <ul class="bg_content-blocks">
              {% for block in section.blocks %}
                {%  if block.type == 'list' %}
                  <li class="bs_content-block fade-in-item">
                    {% if block.settings.icon != blank %}
                        <div class="bs_content-block-icon">
                            {{ block.settings.icon | image_url: width: 160 | image_tag:
                                alt: "image",
                                loading: "lazy"
                            }}
                        </div>
                    {% endif %}
                    {% if block.settings.icon_text != blank %}
                        <span class="bs_content-block-text">{{ block.settings.icon_text }}</span>
                    {% endif %}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

            {% if section.settings.button_text != blank %}
                <a href="{{ section.settings.button_link }}" class="bg_content_button fade-in-up">
                    <span class="her-banner_button-text">{{ section.settings.button_text }}</span>
                    {% if section.settings.button_icon != blank %}
                        <div class="bg_content_button-icon">
                            {{ section.settings.button_icon | image_url: width: 1000 | image_tag:
                                widths: '50, 100, 120',
                                alt: "image",
                                loading: "lazy"
                            }}
                        </div>
                    {% endif %}
                </a>
            {% endif %}
        </div>
    </div>

</section>



{% schema %}
{
  "name": "BG Content Section",
  "settings": [

    {
      "type": "image_picker",
      "id": "main_img",
      "label": "Desktop Banner Image"
    },

    {
      "type": "image_picker",
      "id": "mobile_img",
      "label": "Mobile Banner Image"
    },

    {
      "type": "image_picker",
      "id": "list_icon",
      "label": "List Icon",
      "info": "Select icon, If List is used in Deskcription"
    },

    {
      "type": "richtext",
      "id": "title",
      "label": "Banner Title"
    },

    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },

    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "button_icon_bg",
      "label": "Button Icon Background",
      "default": "#ffffff"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Top Desktop",
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Bottom Desktop",
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Top Mobile",
      "default": 40
    },

    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Bottom Mobile",
      "default": 40
    }

  ],
  "blocks": [
    {
      "type": "list",
      "name": "Icon List",
      "settings": [
        {
            "type": "image_picker",
            "id": "icon",
            "label": "Select an icon"
        },
        {
            "type": "text",
            "id": "icon_text",
            "label": "Icon Text"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Backgroun Content Section",
      "category": "custom"
    }
  ]
}
{% endschema %}
