{% style %}

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  background: {{ section.settings.section_bg }};
}

.section-{{ section.id }} .reviews-head{
  text-align:center;
  margin-bottom: 32px;
}

.section-{{ section.id }} .reviews-ratings{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:10px;
}

.section-{{ section.id }} .reviews-starts_img {
    max-width: 116px;
    width: 100%;
    height: auto;
}

.section-{{ section.id }} .reviews-starts_img img{
  width:100%;
  height: 100%;
  object-fit: cover;
  display:block;
}

.reviews-text {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 0px;
    text-align: center;
    color: #1e1e1e;
}

h2.reviews_title {
    font-family: PP Formula;
    font-weight: 700;
    font-size: 60px;
    line-height: 66px;
    letter-spacing: 1px;
    text-align: center;
    vertical-align: middle;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 18px;
}

.section-{{ section.id }} .reviews_cards{
  position:relative;
}

.section-{{ section.id }} .reviews_card{
  padding:24px;
  background: {{ section.settings.card_bg }};
  border-radius: 12px;
  text-align: center;
}

.reviews-card_image {
    max-width: 116px;
    width: 100%;
    height: auto;
    margin: 0 auto 24px;
}

.section-{{ section.id }} .reviews-card_image img{
  width:100%;
  height: 100%;
  object-fit: cover;
  display:block;
}

.section-{{ section.id }} .reviews-card_desc{
    margin: 0;
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 24px;
    letter-spacing: 0px;
    text-align: center;
    color: #000;
}

span.reviews-card_name {
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 150%;
    letter-spacing: 0px;
    color: #000;
    margin: 20px 0 0;
    display: inline-block;
}

.section-{{ section.id }} .swiper-pagination{
    position: static;
    margin-top: 16px;
}

.section-{{ section.id }} .swiper-pagination-bullet{
  width: 8px;
  height: 8px;
  opacity: 1;
  transition: max-width 0.3s ease;
  background: #000;
}

.section-{{ section.id }} .swiper-pagination-bullet-active{
    max-width: 30px;
    width: 100%;
    border-radius: 10px;
}


/* Mobile */

@media(max-width:768px){

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_mobile }}px;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
}

.section-{{ section.id }} .page-width{
    padding: 0;
}

h2.reviews_title {
    font-size: 40px;
    line-height: 44px;
    margin: 0 0 12px;
}

.section-{{ section.id }} .reviews-starts_img {
    max-width: 100px;
}

.reviews-text,
span.reviews-card_name,
.section-{{ section.id }} .reviews-card_desc {
    font-size: 16px;
}

.section-{{ section.id }} .reviews_card {
    padding: 20px;
}

.section-{{ section.id }} .reviews-head {
    padding: 0 16px;
}

}

{% endstyle %}



<section class="reviews-section section-{{ section.id }} fade-in-section" id="review__sction">
    <div class="page-width">
        <div class="reviews-wrapper">

            <div class="reviews-head fade-in-up">

                {% if section.settings.title != blank %}
                <h2 class="reviews_title">
                    {{ section.settings.title }}
                </h2>
                {% endif %}

                {% if section.settings.subtitle != blank %}
                <p class="reviews_subtitle">
                    {{ section.settings.subtitle }}
                </p>
                {% endif %}

                <div class="reviews-ratings">

                    {% if section.settings.stars_image != blank %}
                    <div class="reviews-starts_img">
                        {{ section.settings.stars_image | image_url: width:200 | image_tag: alt: "image" }}
                    </div>
                    {% endif %}

                    {% if section.settings.rating_text != blank %}
                    <div class="reviews-text">
                        {{ section.settings.rating_text }}
                    </div>
                    {% endif %}

                </div>

            </div>


            <div class="reviews_cards">

                <div class="swiper reviews-swiper-{{ section.id }}">
                    <div class="swiper-wrapper reviews_swiper">

                        {% for block in section.blocks %}
                        <div class="swiper-slide" {{ block.shopify_attributes }}>
                            <div class="reviews_card fade-in-item">

                                {% if block.settings.image != blank %}
                                <div class="reviews-card_image">
                                    {{ block.settings.image | image_url: width:600 | image_tag: alt: "image" }}
                                </div>
                                {% endif %}

                                {% if block.settings.desc != blank %}
                                <p class="reviews-card_desc">
                                    {{ block.settings.desc }}
                                </p>
                                {% endif %}

                                {% if block.settings.name != blank %}
                                <span class="reviews-card_name">
                                    {{ block.settings.name }}
                                </span>
                                {% endif %}

                            </div>
                        </div>
                        {% endfor %}

                    </div>

                    <div class="swiper-pagination reviews-pagination-{{ section.id }}"></div>

                </div>

            </div>

        </div>
    </div>
</section>



<script>
document.addEventListener("DOMContentLoaded", function () {

new Swiper(".reviews-swiper-{{ section.id }}", {
    slidesPerView: 1.1,
    spaceBetween: 6,
    speed: 1500,
    centeredSlides: true,

    pagination: {
        el: ".reviews-pagination-{{ section.id }}",
        clickable: true
    },

    breakpoints: {
        768: {
            slidesPerView: 3,
            spaceBetween: 16,
            centeredSlides: false,
        }
    }

});

});
</script>



{% schema %}
{
  "name": "Reviews Section",
  "settings": [

    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    },

    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle"
    },

    {
      "type": "image_picker",
      "id": "stars_image",
      "label": "Stars Image"
    },

    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text"
    },

    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#F8F6EF"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "min":0,
      "max":200,
      "step":4,
      "default":80,
      "label":"Padding Top Desktop"
    },

    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min":0,
      "max":200,
      "step":4,
      "default":80,
      "label":"Padding Bottom Desktop"
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "min":0,
      "max":200,
      "step":4,
      "default":40,
      "label":"Padding Top Mobile"
    },

    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min":0,
      "max":200,
      "step":4,
      "default":40,
      "label":"Padding Bottom Mobile"
    }

  ],

  "blocks":[
    {
      "type":"review",
      "name":"Review Card",
      "settings":[

        {
          "type":"image_picker",
          "id":"image",
          "label":"Review Image"
        },

        {
          "type":"textarea",
          "id":"desc",
          "label":"Review Text"
        },

        {
          "type":"text",
          "id":"name",
          "label":"Customer Name"
        }

      ]
    }
  ],

  "presets":[
    {
      "name":"Reviews Section",
      "category": "Custom",
      "blocks":[
        {"type":"review"},
        {"type":"review"},
        {"type":"review"}
      ]
    }
  ]
}
{% endschema %}
