{% style %}

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  background: {{ section.settings.section_bg }};
  position: relative;
}

.story-behind-abs_img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.story-behind-abs_img {
    position: absolute;
    top: 0;
    right: 0;
    max-width: 150px;
    width: 100%;
    height: auto;
}

.section-{{ section.id }} .story-behind-wrapper{
  display:flex;
  align-items:center;
  gap: 60px;
  position: relative;
}

.section-{{ section.id }} .story-behind-image{
    max-width: 44%;
    width: 100%;
}

.section-{{ section.id }} .story-behind-image img{
  width:100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.section-{{ section.id }} .story-behind-content{
    max-width: calc(100% - (44% + 60px));
    width: 100%;
}

.story-behind-content_inner {
    max-width: 504px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 32px;
}

.section-{{ section.id }} .story-behind-title{
    margin: 0;
    font-family: PP Formula;
    font-weight: 700;
    font-size: 60px;
    line-height: 66px;
    letter-spacing: 2px;
    vertical-align: middle;
    text-transform: uppercase;
    color: #000;
}

.section-{{ section.id }} .story-behind-desc{
    margin: 0;
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
}

.story-behind-desc ul {
    padding: 0;
    margin: 24px 0 0;
    display: flex;
    flex-direction: column;
    gap: 13px;
    list-style-type: none;
}

.story-behind-desc ul li {
    display: flex;
    gap: 15px;
    font-family: GT Cinetype;
    font-weight: 400;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: #000;
    align-items: center;
}

.story-behind-desc ul li:before {
    content: "";
    min-width: 24px;
    width: 24px;
    height: 24px;
    background-image: url('{{ section.settings.list_icon | image_url }}');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
}

.section-{{ section.id }} .story-behind-desc p {
    margin: 0;
}

.section-{{ section.id }} .story-behind-button{
  display:inline-flex;
  align-items:center;
  gap:10px;
  text-decoration:none;
  background: {{ section.settings.button_bg }};
  padding:10px 16px;
  border-radius:75px;
  transition:all .3s ease;
  max-width: fit-content;
}

.section-{{ section.id }} .story-behind-button:hover {
  transform:translateY(-2px);
}

.section-{{ section.id }} .story-behind-button:hover .story-behind-btn-icon{
  transform:translateX(4px);
}

span.story-behind-btn-text {
    color: #fff;
    font-family: GT Cinetype;
    font-weight: 700;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0px;
    text-transform: uppercase;
}

.section-{{ section.id }} .story-behind-btn-icon{
  background: {{ section.settings.button_icon_bg }};
  display:flex;
  align-items:center;
  justify-content:center;
  padding:10px 12px;
  border-radius:60px;
  transition:all .3s ease;
}

.section-{{ section.id }} .story-behind-btn-icon img{
  width: 26px;
  height: 16px;
  object-fit: cover;
  display:block;
}

/* ======== pdp styleing ===== */

.story-behind-content_pdp-{{ section.id }} .story-behind-content_inner {
    max-width: 100%;
    gap: 12px;
}

.story-behind-content_pdp-{{ section.id }} a.story-behind-button {
    margin-top: 30px;
}

.story-behind-content_pdp-{{ section.id }} .story-behind-desc {
    max-width: 594px;
}


/* Mobile */

@media(max-width:768px){

.section-{{ section.id }}{
  padding-top: {{ section.settings.padding_top_mobile }}px;
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
}

.story-behind-desc ul li {
    font-size: 16px;
}

.section-{{ section.id }} .story-behind-wrapper{
  flex-direction:column;
  gap: 32px;
}

.section-{{ section.id }} .story-behind-image {
    max-width: 100%;
    padding: 0 10px;
}

.section-{{ section.id }} .story-behind-content {
    max-width: 100%;
    width: 100%;
}

.story-behind-content_inner {
    max-width: 100%;
    gap: 24px;
}

.section-{{ section.id }} .story-behind-title {
    font-size: 40px;
    line-height: 44px;
    letter-spacing: 1px;
    max-width: 306px;
}

.section-{{ section.id }} .story-behind-desc {
    font-size: 16px;
}



.pdp-{{ section.id }} .story-behind-wrapper {
    flex-direction: column;
    gap: 24px;
}

.story-behind-content_pdp-{{ section.id }} .story-behind-content_inner {
    max-width: 100%;
    gap: 24px;
}

.pdp-{{ section.id }} .story-behind-title {
    font-size: 32px;
    line-height: 100%;
    letter-spacing: 2px;
    max-width: 100%;
}

.pdp-{{ section.id }} .story-behind-desc ul {
    padding: 0;
    margin: 16px 0 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style-type: none;
}

.story-behind-content_pdp-{{ section.id }} a.story-behind-button {
    margin-top: 0;
}

}

{% endstyle %}


<section class="fade-in-section section-{{ section.id }} {% if section.settings.pdp %} pdp-{{ section.id }} {% endif %}">
    {% if section.settings.abs_image != blank %}
        <div class="story-behind-abs_img">
            {{ section.settings.abs_image | image_url: width:1600 | image_tag }}
        </div>
    {% endif %}
    <div class="page-width">
        <div class="story-behind-wrapper">

            {% if section.settings.image != blank %}
            <div class="story-behind-image">
                {{ section.settings.image | image_url: width:1600 | image_tag }}
            </div>
            {% endif %}

            <div class="story-behind-content {% if section.settings.pdp %} story-behind-content_pdp-{{ section.id }} {% endif %}">
                <div class="story-behind-content_inner fade-in-up">
                    {% if section.settings.title != blank %}
                    <h2 class="story-behind-title">
                        {{ section.settings.title | replace: '<p>', '' | replace: '</p>', '' }}
                    </h2>
                    {% endif %}
    
                    {% if section.settings.description != blank %}
                    <div class="story-behind-desc">
                        {{ section.settings.description }}
                    </div>
                    {% endif %}
    
                    {% if section.settings.button_text != blank %}
                    <a href="{{ section.settings.button_link }}" class="story-behind-button">
    
                        <span class="story-behind-btn-text">
                            {{ section.settings.button_text }}
                        </span>
    
                        {% if section.settings.button_icon != blank %}
                        <div class="story-behind-btn-icon">
                            {{ section.settings.button_icon | image_url: width:100 | image_tag }}
                        </div>
                        {% endif %}
                    </a>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</section>


{% schema %}
{
  "name": "Story Behind Section",
  "settings": [

    {
      "type": "checkbox",
      "id": "pdp",
      "label": "PDP Style",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "abs_image",
      "label": "Section Absolute Image"
    },

    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },

    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },

    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },

    {
      "type": "image_picker",
      "id": "list_icon",
      "label": "List Icon"
    },

    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },

    {
      "type": "image_picker",
      "id": "button_icon",
      "label": "Button Icon"
    },

    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },

    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#000000"
    },

    {
      "type": "color",
      "id": "button_icon_bg",
      "label": "Button Icon Background",
      "default": "#ffffff"
    },

    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Top Desktop",
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Bottom Desktop",
      "default": 80
    },

    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Top Mobile",
      "default": 40
    },

    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "label": "Padding Bottom Mobile",
      "default": 40
    }

  ],

  "presets":[
    {
      "name":"Story Behind Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
