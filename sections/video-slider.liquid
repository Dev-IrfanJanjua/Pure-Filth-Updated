      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Padding Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "items_primary_color",
      "label": "Items Primary Color",
      "info": "Dark and Primary Color for icons"
    },
    {
      "type": "color_background",
      "id": "items_light_color",
      "label": "Video Path Color",
      "info": "Video Path BG Light"
    }
  ],
  "presets": [
    {
      "name": "Video Slider Formulas",
      "category": "Custom"
    }
  ]
}
